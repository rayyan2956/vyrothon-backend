# Database (async driver for the app)
DATABASE_URL=postgresql+asyncpg://grabpic:grabpic_secret@localhost:5432/grabpic_db

# Database (sync driver for Alembic migrations)
SYNC_DATABASE_URL=postgresql+psycopg2://grabpic:grabpic_secret@localhost:5432/grabpic_db

# Directory where ingested images are stored
UPLOAD_DIR=./uploads

# Cosine similarity threshold for face matching (0.0 – 1.0)
# Higher = stricter matching, Lower = more lenient
SIMILARITY_THRESHOLD=0.50
